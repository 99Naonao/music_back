# 乐伴好眠 — 上传封面 404 修复（宝塔 / Nginx）
#
# 现象：POST /api/upload/image 成功，但浏览器打开
#   https://域名/api/music/cover/xxx.png  → 404.html
# 原因：站点常有一条「按后缀匹配静态图」的规则，*.png 不会反代到 Node。
#
# 方案 A（推荐，代码已支持）：封面 URL 使用查询参数，路径无 .png 后缀
#   https://music.zsyl.cc/api/music/cover?f=image-xxx.png
# 部署新版 Node 后无需改 Nginx。
#
# 方案 B：在「伪静态 / 配置文件」里，让 /api/ 优先于静态图规则，例如：
#
# location ^~ /api/ {
#     proxy_pass http://127.0.0.1:3000;
#     proxy_http_version 1.1;
#     proxy_set_header Host $host;
#     proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
# }
#
# 方案 C：上传目录静态别名（.env 设 UPLOAD_PUBLIC_PATH=uploads）
# location ^~ /uploads/ {
#     alias /www/wwwroot/music_sleep_api/data/uploads/;
#     expires 30d;
# }
#
# 作品音频落盘目录（生成后自动下载）：
#   {UPLOAD_DIR}/music-audio/audio-{作品ID}.mp3
# 对外地址（推荐，无 .mp3 路径后缀）：
#   https://music.zsyl.cc/api/music/audio?f=audio-{作品ID}.mp3
#
# 官方曲库（data/audio/library/track1.mp3）：
#   https://music.zsyl.cc/api/music/library-audio?f=track1.mp3
# 勿用 /audio/library/track1.mp3（易被 Nginx *.mp3 静态规则 404）
