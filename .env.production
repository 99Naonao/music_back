# 乐伴好眠App - 生产环境配置
# 请将 .env.example 复制为 .env 并填写实际的生产环境值

# 服务器配置
PORT=3000
# 须与小程序 request 合法域名一致（当前为 music.zsyl.cc）
BASE_URL=https://music.zsyl.cc
# 上传落盘（与服务器实际目录一致）
UPLOAD_DIR=/www/wwwroot/music_sleep_api/data/uploads
# 对外图片 URL：api=/api/music/cover?f=xxx（推荐，避免 Nginx 拦截 *.png）；uploads=需 Nginx alias
UPLOAD_PUBLIC_PATH=api

# 按天业务日志：填 logs 根目录，实际写入 logs/log/app-日期.log
LOG_DIR=/www/wwwroot/music_sleep_api/logs
LOG_RETAIN_DAYS=30
LOG_CONSOLE=1

# 微信小程序配置
WX_APP_ID=your_wx_app_id_here
WX_APP_SECRET=your_wx_app_secret_here

# MiniMax AI 音乐生成配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_BASE=https://api.minimax.chat/v1

# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com

# ==========================================
# 数据库配置（生产环境使用绝对路径）
# ==========================================
DB_PATH=/www/wwwroot/music_sleep_api/data/sleep_music_v2.db
# 官方曲库（与 DB 同项目；不设则自动为 {DB_PATH 所在目录}/audio/library）
# LIBRARY_AUDIO_DIR=/www/wwwroot/music_sleep_api/data/audio/library

# ==========================================
# CORS 跨域配置（生产环境限制为正式域名）
# ==========================================
ALLOWED_ORIGINS=https://your-domain.com

# ==========================================
# 管理密钥（意见反馈 + 盒友圈查删帖共用 ?secret=）
# ==========================================
# FEEDBACK_ADMIN_SECRET=your_feedback_admin_secret
