# 乐伴好眠App 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 或使用对应环境的配置文件：
#   .env.development - 开发环境
#   .env.production  - 生产环境

# 服务器配置
PORT=3000
BASE_URL=http://localhost:3000

# 日志（宝塔生产建议绝对路径；按自然日切割 app-YYYY-MM-DD.log / error-YYYY-MM-DD.log）
# 填 logs 根目录；按天业务日志自动写入 LOG_DIR/log/（与宝塔进程日志区分）
# LOG_DIR=/www/wwwroot/music_sleep_api/logs
# LOG_RETAIN_DAYS=30
# LOG_CONSOLE=1
# REQUEST_LOG_STATIC=0
# 上传落盘目录（生产与 DB 同项目目录）
UPLOAD_DIR=/www/wwwroot/music_sleep_api/data/uploads
# 官方曲库 mp3 目录（默认与 DB_PATH 同级的 data/audio/library）
# LIBRARY_AUDIO_DIR=/www/wwwroot/music_sleep_api/data/audio/library
# 官方曲库封面子目录（默认 muisc_img，与 images/muisc_img/trackN.png 一致）
# LIBRARY_COVER_SUBDIR=muisc_img
# 对外播放：https://域名/api/music/library-audio?f=track1.mp3
# 对外访问路径：api=经 /api 反代可读（推荐）；uploads=需 Nginx 单独配置 /uploads 别名
# UPLOAD_PUBLIC_PATH=api
# 作品音频落盘：{UPLOAD_DIR}/music-audio/audio-{作品ID}.mp3
# 对外播放：https://域名/api/music/audio?f=audio-{作品ID}.mp3（勿用带 .mp3 路径后缀，避免 Nginx 静态规则）
# 进程时区（影响 Node 与 SQLite localtime；未设置时代码里会默认 Asia/Shanghai）
# TZ=Asia/Shanghai

# 微信小程序配置（单应用兼容，与下方多应用二选一或并存）
WX_APP_ID=your_wx_app_id_here
WX_APP_SECRET=your_wx_app_secret_here

# 多小程序同后端（方案二）：music + 睡眠耳机 等
# 未传请求头 X-WX-App-Id 时使用默认 AppID（建议填 music）
WX_DEFAULT_APP_ID=wx21440a46657349c7
WX_APP_ID_MUSIC=wx21440a46657349c7
WX_APP_SECRET_MUSIC=your_music_app_secret
WX_APP_ID_SLEEP=wx86885bed7cfcc1e9
WX_APP_SECRET_SLEEP=your_sleep_device_app_secret
# 智合枕（眠加智合枕）
WX_APP_ID_ZHIHEZHEN=wx43c54dcd8642d95b
WX_APP_SECRET_ZHIHEZHEN=your_zhihezhen_app_secret
# 观心枕（眠加智能观心枕）
WX_APP_ID_GUANXINZHEN=wxc907a3357b4d9f99
WX_APP_SECRET_GUANXINZHEN=your_guanxinzhen_app_secret
# 或使用 JSON 一次性配置微信 AppId/AppSecret（会覆盖上面对应项）：
# WX_MINI_APPS={"wx21440a46657349c7":"music_secret","wx86885bed7cfcc1e9":"sleep_secret","wx43c54dcd8642d95b":"zhihe_secret","wxc907a3357b4d9f99":"guanxin_secret"}
# 内容安全：生产环境勿设为 true（会跳过 msgSecCheck / imgSecCheck / media_check_async）
# SKIP_CONTENT_SEC_CHECK=false
# 本地补充敏感词（逗号分隔，命中即拦截，与微信检测叠加）
# CONTENT_BLOCK_KEYWORDS=代开发票,刷单
# 多媒体异步审核回调 Token（公众平台消息推送 URL：/api/wechat/msg-push）
# WX_MSG_TOKEN=your_msg_push_token

# MiniMax AI 音乐生成配置
MINIMAX_API_KEY=your_minimax_api_key_here
# 与文档 servers 一致，需含 /v1：https://api.minimaxi.com/v1 （旧域名 minimax.chat 若仍可用可自备）
MINIMAX_API_BASE=https://api.minimaxi.com/v1
# 文档枚举：music-2.6 | music-2.6-free | music-cover | music-cover-free
MINIMAX_MUSIC_MODEL=music-2.6-free
# 创作页开启「参考音乐」时使用（须传 audio_url，时长 6 秒～6 分钟）：music-cover | music-cover-free
MINIMAX_COVER_MODEL=music-cover-free
# MiniMax 拉取参考音频用的公网根地址（与小程序 API_BASE_URL 一致，如 https://music.zsyl.cc）
# BASE_URL=https://music.zsyl.cc
# 等 MiniMax「创建任务」POST 返回的最长等待（毫秒）；默认 6 分钟（排队/长提示词时易超 3 分钟）
# MINIMAX_GENERATE_TIMEOUT_MS=360000
# MiniMax 异步任务轮询：服务端每 3s GET 一次状态；默认 120 次≈6 分钟（合成久可调大）
# MINIMAX_POLL_MAX_ATTEMPTS=120
# 提示词里「目标时长」的分钟数（无 duration 入参时）；与 /api/music/create 的 duration(秒) 会换算后优先生效
# MINIMAX_MUSIC_DURATION_MINUTES=3

# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com 

# ==========================================
# 数据库配置
# ==========================================
# SQLite 数据库文件路径
# 开发环境：./data/sleep_music_v2.db
# 生产环境：/www/wwwroot/music_sleep_api/data/sleep_music_v2.db
DB_PATH=./data/sleep_music_v2.db

# ==========================================
# CORS 跨域配置
# ==========================================
# 允许访问的前端域名（多个用逗号分隔）
# 开发环境：*
# 生产环境：https://your-domain.com
ALLOWED_ORIGINS=*

# ==========================================
# 星鹿商城 zhongshu.xinglu.shop（手机号静默注册 + 个人中心 + 扣积分）
# ==========================================
SHOP_API_BASE=https://zhongshu.xinglu.shop
SHOP_API_VERSION=1
# SHOP_API_TIMEOUT_MS=20000
# 登录解密手机号后是否调用 /shopapi/Login/silentLoginByMobile（默认 true）
# SHOP_SYNC_LOGIN=true
# 同步失败是否阻断登录（默认 false）
# SHOP_LOGIN_REQUIRED=false
# 同步成功后是否用商城昵称/头像覆盖本地（默认 false）
# SHOP_MERGE_PROFILE=false
# 是否在登录响应里返回 shopToken（默认 false，建议走 /api/shop/* 代理）
# SHOP_EXPOSE_TOKEN=false
# 星鹿返回「登录超时」等时，是否用手机号自动 silentLogin 刷新 shop_token 并重试一次（默认 true）
# SHOP_AUTO_REFRESH_ON_TIMEOUT=true
#
# 每日任务发放积分：与扣积分同为 POST /shopapi/User/thirdDeduct，multipart 增加字段 action=2（增加），不传 action 默认扣减
#
# 任务积分渠道：shop=调星鹿 thirdDeduct（action=2）（默认）；local=仅写入本库 user_points（联调）
# TASK_POINTS_MODE=shop

# ==========================================
# 智合枕 / 观心枕 bed.qssmart.cn 访问令牌（GetAccessToken → /api/detection/token）
# 各小程序使用各自的 bed API key（GetAccessToken 请求参数 key）
# ==========================================
# BED_SOAP_URL=https://bed.qssmart.cn/CustomerAPIService.asmx
# BED_SOAP_USERNAME=customerapi
# BED_SOAP_PASSWORD=pA2@G8zQ
# BED_SOAP_TIMEOUT_MS=20000
# 兼容：所有未单独配置的小程序共用此 key
# BED_API_KEY=1f3e1d08bac85daf08eca14e72cde665
# 推荐：按 AppId 配置各自的 bed key（JSON）
# BED_TOKEN_APP_KEYS={"wx43c54dcd8642d95b":"智合枕的bed_key","wxc907a3357b4d9f99":"1f3e1d08bac85daf08eca14e72cde665"}
# 或带名称：
# BED_TOKEN_APP_KEYS={"wx43c54dcd8642d95b":{"name":"智合枕","bedApiKey":"xxx"},"wxc907a3357b4d9f99":{"name":"观心枕","bedApiKey":"1f3e1d08bac85daf08eca14e72cde665"}}

# ==========================================
# 静态图片（商城 / 贺卡 PNG，目录：项目根 images/）
# ==========================================
# MALL_IMAGE_BASE=https://music.zsyl.cc
# 商品小程序码：images/qrcode/{商品id}.png（文件名=积分商城 id 或眠家 goodsId）
# 静态访问：https://music.zsyl.cc/images/qrcode/10020.png
# API 默认返回 qrcodeUrl；小程序仅在「兑换成功 / 查看凭证」时使用，不在详情首屏展示
# MALL_EXPOSE_QRCODE=false
# 是否在小程序展示「查看领取凭证」入口（需为 true 且商品有 qrcode 文件时，API 才返回 showVoucher:true）
# MALL_VOUCHER_UI_VISIBLE=true
# 贺卡模板 manifest 同步接口密钥（POST /api/card/templates/sync）
# CARD_TEMPLATE_SYNC_SECRET=your_sync_secret
#
# 管理密钥（意见反馈 + 盒友圈查删帖共用，只配这一项即可）
# GET  /api/feedback?secret=xxx&page=1&limit=20
# GET  /api/community/admin/posts?secret=xxx&q=关键词
# DELETE /api/community/admin/post/{postId}?secret=xxx
# FEEDBACK_ADMIN_SECRET=your_feedback_admin_secret

# ---------- 运营后台 Admin（Step 0/1 · music.zsyl.cc/admin 同域） ----------
# 页面路径：/admin/（Nginx 静态，见 deploy/nginx-admin.conf.example）
# API 前缀：/api/admin/*（与小程序 /api/* 分离；小程序 Bearer 不可用于 Admin）
# ADMIN_SESSION_TTL_HOURS=168
# ADMIN_COOKIE_SECURE=1
# 首次创建 super：node scripts/seed-admin.js --username admin --password '强密码至少8位'
# 或：ADMIN_SEED_USERNAME=admin ADMIN_SEED_PASSWORD=xxx npm run seed:admin
# 可选：单独覆盖盒友圈密钥（一般不配，与上项相同）
# COMMUNITY_ADMIN_SECRET=
